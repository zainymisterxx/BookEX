{
  "name": "bookex",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:next\" \"npm:dev:socket\"",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "dev:next": "next dev --turbopack -p 9002",
    "dev:socket": "tsx watch server.ts",
    "setup:db": "tsx scripts/setup-database.ts",
    "optimize:db": "tsx scripts/optimize-database.ts",
    "setup:indexes": "tsx scripts/setup-critical-indexes.ts",
    "file:cleanup": "tsx scripts/file-security-maintenance.ts",
    "business:maintenance": "tsx scripts/business-logic-maintenance.ts",
    "content:maintenance": "tsx scripts/content-moderation-maintenance.ts",
    "security:audit": "npm audit && npm audit --audit-level high"
  },
