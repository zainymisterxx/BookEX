# BookEX Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# Node Environment
# ============================================
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
# MongoDB connection string
# Format: mongodb://username:password@host:port/database
# Or for MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb://localhost:27017/bookex

# ============================================
# Authentication (NextAuth.js)
# ============================================
# Secret key for JWT encryption (REQUIRED)
# Generate with: openssl rand -base64 32
# MUST be at least 32 characters
NEXTAUTH_SECRET=your-secret-key-here-min-32-characters

# Application URL (REQUIRED)
# The URL where your application is deployed
NEXTAUTH_URL=http://localhost:9002

# ============================================
# Google OAuth (REQUIRED for authentication)
# ============================================
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# Application URLs
# ============================================
# Public-facing application URL (REQUIRED)
NEXT_PUBLIC_APP_URL=http://localhost:9002

# ============================================
# Socket.IO Configuration
# ============================================
# Port for Socket.IO server (default: 3001)
SOCKET_PORT=3001

# Socket.IO server URL (optional, defaults to NEXT_PUBLIC_APP_URL:SOCKET_PORT)
# Use this if Socket.IO server is on a different domain
SOCKET_URL=http://localhost:3001

# ============================================
# Redis Configuration (Optional)
# ============================================
# Redis is used for caching and rate limiting
# Application will work without Redis but with reduced performance

# Option 1: Individual connection parameters
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Option 2: Complete Redis URL (takes precedence over individual parameters)
# Format: redis://username:password@host:port
# REDIS_URL=redis://localhost:6379

# ============================================
# Email Configuration (Optional)
# ============================================
# Email settings for sending notifications
# Currently using Nodemailer, supports SMTP servers

# From address for outgoing emails
EMAIL_FROM=noreply@bookex.com

# SMTP server configuration
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your-smtp-username
EMAIL_SERVER_PASSWORD=your-smtp-password

# ============================================
# Google AI (Optional)
# ============================================
# For AI-powered features (book recommendations, content moderation)
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_GENAI_API_KEY=your-google-ai-api-key

# ============================================
# Production Configuration (when deploying)
# ============================================
# When deploying to production:
# 1. Set NODE_ENV=production
# 2. Update NEXTAUTH_URL to your production domain
# 3. Update NEXT_PUBLIC_APP_URL to your production domain
# 4. Update SOCKET_URL if Socket.IO is on a different domain
# 5. Use strong, unique NEXTAUTH_SECRET
# 6. Enable Redis for better performance
# 7. Configure proper email SMTP settings

# Example production values:
# NODE_ENV=production
# NEXTAUTH_URL=https://yourdomain.com
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
# SOCKET_URL=https://socket.yourdomain.com
# NEXTAUTH_SECRET=<generate-a-strong-secret>
# MONGODB_URI=<your-production-mongodb-uri>
# REDIS_URL=<your-production-redis-uri>

# ============================================
# Development Notes
# ============================================
# - Never commit the actual .env file to git
# - Keep .env.example updated when adding new variables
# - Document each variable's purpose and format
# - Use .env.local for local overrides (also ignored by git)
# - Validate all required variables on startup

# ============================================
# Media API (required for image uploads)
# ============================================
MEDIA_API_SECRET=your-media-api-secret-here
NEXT_PUBLIC_MEDIA_API_URL=http://localhost:4010
NEXT_PUBLIC_MEDIA_PUBLIC_URL=http://localhost:4010
MEDIA_PORT=4010
MEDIA_BIND_HOST=0.0.0.0
MEDIA_STORAGE_ROOT=/var/www/bookex/uploads

# ============================================
# Admin
# ============================================
ADMIN_EMAIL=admin@yourapp.com
RESEND_API_KEY=re_HP8NgRdB_wCDQvHPNaqWz3iHh19XPKUfw