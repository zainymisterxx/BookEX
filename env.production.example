# BookEx Production Environment Variables
# Copy this file to .env.local for local development or set these in Vercel dashboard

# =============================================================================
# REQUIRED - Core Application Settings
# =============================================================================

# NextAuth Configuration (REQUIRED)
NEXTAUTH_SECRET=your-super-secret-nextauth-key-here
NEXTAUTH_URL=https://your-app.vercel.app

# Database Configuration (REQUIRED)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bookex?retryWrites=true&w=majority

# =============================================================================
# REQUIRED - Frontend Accessible URLs (NEXT_PUBLIC_*)
# =============================================================================

# Application Base URL (REQUIRED for production)
# This is the public URL of your deployed app
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Socket.IO Server URL (REQUIRED for real-time features)
# In production, this should be the same as your app URL since Socket.IO runs on the same server
NEXT_PUBLIC_SOCKET_URL=https://your-app.vercel.app

# API Base URL (OPTIONAL - defaults to NEXT_PUBLIC_APP_URL/api)
# Only set if you want to use a different API server
# NEXT_PUBLIC_API_URL=https://your-app.vercel.app/api

# =============================================================================
# REQUIRED - AI/ML Services
# =============================================================================

# Google AI API Key for Gemini (REQUIRED for AI features)
GEMINI_API_KEY=your-google-ai-api-key-here

# =============================================================================
# OPTIONAL - Email Configuration
# =============================================================================

# Email Service Configuration (OPTIONAL - for email notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com

# Admin Email for Notifications (OPTIONAL)
ADMIN_EMAIL=admin@yourdomain.com

# =============================================================================
# OPTIONAL - Caching & Performance
# =============================================================================

# Redis URL for caching and rate limiting (OPTIONAL - app works without it)
REDIS_URL=redis://localhost:6379

# =============================================================================
# OPTIONAL - File Storage & Security
# =============================================================================

# Secure Upload Directory (OPTIONAL - defaults to ./secure-uploads)
SECURE_UPLOAD_DIR=./secure-uploads

# Quarantine Directory for suspicious files (OPTIONAL - defaults to ./quarantine)
QUARANTINE_DIR=./quarantine

# =============================================================================
# OPTIONAL - Socket.IO Configuration
# =============================================================================

# Socket.IO Server Port (OPTIONAL - defaults to 3001)
# Note: In production on Vercel, this is handled automatically
SOCKET_PORT=3001

# =============================================================================
# VERCEL-SPECIFIC VARIABLES (AUTOMATICALLY SET BY VERCEL)
# =============================================================================

# These are automatically provided by Vercel - DO NOT set manually
# VERCEL_URL=your-app.vercel.app
# VERCEL_ENV=production
# VERCEL_REGION=iad1

# =============================================================================
# DEVELOPMENT-ONLY VARIABLES (DO NOT SET IN PRODUCTION)
# =============================================================================

# These are only used in development - DO NOT set in Vercel
# NODE_ENV=development
# PORT=9002
